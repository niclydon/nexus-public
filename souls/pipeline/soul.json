    "minTokenContext": 8192
  },
  "allowedTools": [
    "query_db",
    "check_system",
    "inbox_send",
    "remember",
    "search_tools",
    "request_tool",
    "escalate",
    "pushover_notify",
    "enqueue_job",
    "update_source_config",
    "notion__*",
    "apple-photos__*",
    "gmail__*",
    "google-drive__*",
    "brave-search__*"
  ],
  "files": {
    "soul": "SOUL.md",
    "identity": "IDENTITY.md",
    "agents": "AGENTS.md",
    "reference": "REFERENCE.md"
  },
  "disclosure": {
    "summary": "Monitors 14 data sources, orchestrates enrichment pipelines, coordinates Mac relay."
  },
  "deprecated": false,
  "nexus": {
    "schedule_interval_sec": 300,
    "autonomy": "moderate",
    "executor": "nexus",
    "llm_config": {
      "model": "qwen3-next-chat-80b",
      "url": "http://localhost:8088/v1"
    },
    "absorbs": [
      "queue-manager",
      "sync-orchestrator",
      "data-steward"
    ],
    "response_schema": "nexus-v2"
  }
