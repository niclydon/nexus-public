{
  "specVersion": "0.5",
  "name": "pipeline",
  "displayName": "Collector",
  "version": "2.0.0",
  "description": "Data ingestion orchestrator \u2014 source health, relay coordination, enrichment pipelines.",
  "author": {
    "name": "Anonymous",
    "github": "anonymous"
  },
  "license": "Apache-2.0",
  "tags": [
    "data",
    "ingestion",
    "pipelines",
    "relay",
    "backfill"
  ],
  "category": "operations/data",
  "compatibility": {
    "frameworks": [
      "nexus"
    ],
    "models": [
      "qwen3-next-chat-80b"
