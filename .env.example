# Nexus Platform Environment Variables
# Copy to .env and fill in values

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nexus

# ── LLM Inference ───────────────────────────────────────────────────
# Local LLM gateway (OpenAI-compatible API)
FORGE_URL=http://localhost:8080
FORGE_API_KEY=

# Cloud LLM providers (fallback chain)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=

# ── Authentication ──────────────────────────────────────────────────
# System key for internal callers (worker, dashboard)
# Generate: node -e "console.log('nexus_sys_' + require('crypto').randomBytes(32).toString('hex'))"
NEXUS_SYSTEM_KEY=

# ── Notifications ───────────────────────────────────────────────────
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
RESEND_API_KEY=

# ── MCP Server Auth ─────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
CLOUDFLARE_API_TOKEN=
NOTION_TOKEN=
BRAVE_SEARCH_API_KEY=

# ── Logging ─────────────────────────────────────────────────────────
# minimal | normal | verbose | debug
LOG_LEVEL=normal

# ── API Server ──────────────────────────────────────────────────────
PORT=7700
